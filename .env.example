# =============================================
# Project Fly — environment variables
# Copy this file to .env and fill in values
# =============================================

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# Flask
FLASK_DEBUG=True   # Set to False in production

# CORS: comma-separated allowed origins
# Development: CORS_ORIGINS=*
# Production:  CORS_ORIGINS=https://your-app.netlify.app
CORS_ORIGINS=*

# Frontend (set in Netlify → Site settings → Environment variables)
# Leave empty locally — Vite dev proxy handles /api/* automatically
VITE_API_BASE_URL=https://your-backend.up.railway.app
